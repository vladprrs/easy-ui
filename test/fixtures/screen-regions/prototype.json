{
  "version": 1,
  "id": "screen-regions",
  "name": "Screen regions",
  "designSystem": "screen-regions-custom",
  "device": "mobile",
  "startScreen": "main",
  "state": {},
  "screens": [
    {
      "id": "main",
      "name": "Main",
      "spec": {
        "root": "root",
