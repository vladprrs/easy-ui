{
  "version": 1,
  "id": "rating-demo",
  "name": "Rating Demo",
  "description": "Custom RatingStars component inside a two-screen flow.",
  "device": "mobile",
  "startScreen": "rate",
  "state": { "clicks": 0 },
  "screens": [
    {
      "id": "rate",
      "name": "Rate",
      "spec": {
        "root": "card",
        "elements": {
          "card": { "type": "Card", "props": { "title": "Оцените нас" }, "children": ["stars", "count", "next"] },
          "stars": {
            "type": "RatingStars",
            "props": { "value": 3, "label": "Рейтинг" },
            "on": { "press": { "action": "setState", "params": { "statePath": "/clicks", "value": 1 } } }
          },
          "count": {
            "type": "Text",
            "props": { "text": { "$cond": { "if": { "$state": "/clicks" }, "then": "Спасибо за оценку!", "else": "Ещё не оценено" } } }
          },
          "next": { "type": "Button", "props": { "label": "Дальше" }, "on": { "press": { "action": "navigate", "params": { "screenId": "done" } } } }
        }
      }
    },
    {
      "id": "done",
      "name": "Done",
      "spec": {
        "root": "card",
        "elements": {
          "card": { "type": "Card", "props": { "title": "Готово" }, "children": ["copy", "back"] },
          "copy": { "type": "Text", "props": { "text": "Второй экран." } },
          "back": { "type": "Button", "props": { "label": "Назад" }, "on": { "press": { "action": "back", "params": {} } } }
        }
      }
    }
  ]
}
