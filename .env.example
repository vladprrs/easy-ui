# Dokploy API key (Dokploy UI -> Settings -> API/CLI) — used by .claude/skills/deploy/driver.mjs
DOKPLOY_API_KEY=

# Named account used for cookie-session login and post-deploy verify checks.
EASYUI_USERNAME=admin
EASYUI_PASSWORD=

# Named bootstrap administrator used for cookie-session login. Set both values together.
ADMIN_NAME=admin
ADMIN_PASSWORD=

# Optional outer Basic barrier ("user:password"). Removed from prod 2026-07-20; the server
# still honors LEGACY_BASIC_AUTH (and BASIC_AUTH as a deprecated alias) if set.
LEGACY_BASIC_AUTH=

# Canonical browser origin used to generate scoped share/QR links (scheme + host only).
# Production/non-loopback origins must use HTTPS. Local auth-preview may use explicit HTTP.
PUBLIC_ORIGIN=https://easy-ui.pay-offline.ru
