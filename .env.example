# Dokploy API key (Dokploy UI -> Settings -> API/CLI) — used by .claude/skills/deploy/driver.mjs
DOKPLOY_API_KEY=
# Basic-auth credentials of the deployed easy-ui instance, "user:password" (optional, for authed verify checks)
EASY_UI_BASIC_AUTH=

# Runtime credentials consumed by docker-compose.yml (set as a secret in production).
BASIC_AUTH=

# Canonical browser origin used to generate scoped share/QR links (scheme + host only).
# Production/non-loopback origins must use HTTPS. Local auth-preview may use explicit HTTP.
PUBLIC_ORIGIN=https://easy-ui.pay-offline.ru
